# VisionEdge — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains secrets.
# This file (.env.example) IS committed — it documents all required variables.

# ── Shared ──────────────────────────────────────────────────────────────────

# URL of the cloud backend (Person B's FastAPI server)
BACKEND_URL=http://localhost:8000

# ── Edge Agent (Person A) ────────────────────────────────────────────────────

# Agent token issued by backend for this site (POST /api/v1/sites → agent_token)
AGENT_TOKEN=demo-secret-123

# Site ID assigned by backend
SITE_ID=your-site-uuid-here

# RTSP URL of the camera to connect to
# WiFi cam example:  rtsp://admin:password@192.168.1.x:554/stream1
# Tapo example:      rtsp://username:password@192.168.1.x:554/stream1
# Reolink example:   rtsp://admin:password@192.168.1.x:554/h264Preview_01_main
CAMERA_RTSP_URL=rtsp://admin:password@192.168.1.x:554/stream1

# Port for HLS streaming server (Phase 4)
HLS_PORT=8080

# InsightFace device: -1=CPU, 0=first GPU (use -1 on dev PC, 0 on Jetson with GPU)
INSIGHTFACE_CTX_ID=-1

# InsightFace detection threshold: 0.3=sensitive (foggy/blur), 0.5=strict (clean footage)
INSIGHTFACE_DET_THRESH=0.3

# Path where the local SQLite database is stored
DB_PATH=/var/lib/visionedge/edge-agent.db

# Path to save event frame snapshots before upload
FRAME_SNAPSHOT_DIR=/var/lib/visionedge/frames

# Face recognition confidence threshold (only send events above this)
RECOGNITION_THRESHOLD=0.95

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Backend (Person B) ───────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://visionedge:dev@localhost:5432/visionedge

# Redis connection string (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# JWT signing secret — must be long and random in production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-random-secret

# Agent token signing secret (separate from user JWT secret)
AGENT_SECRET=change-me-generate-a-random-agent-secret

# AES-256 encryption key for face embeddings at rest (32 bytes, base64 encoded)
# Generate: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
FACE_ENCRYPTION_KEY=change-me-generate-a-random-key

# Firebase service account JSON path (for FCM push notifications — Phase 3)
FIREBASE_SERVICE_ACCOUNT_PATH=/etc/visionedge/firebase-service-account.json

# WhatsApp Business API token (Phase 3)
WHATSAPP_API_TOKEN=your-whatsapp-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
